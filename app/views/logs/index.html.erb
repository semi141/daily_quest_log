<div class="container mt-4">
<%= link_to "新しくセーブする", new_log_path, class: "btn btn-success" %>
  <div class="row">
    <% @logs.each do |log| %>
      <div class="col-md-4 mb-4">
        <div class="card h-100">
          <div class="card-body d-flex flex-column">
            <h5 class="card-title"><%= log.title %></h5>

            <p class="card-text mb-2">
              <strong>Design:</strong>
              <%= truncate(log.design.to_s, length: 60) %>
            </p>

            <p class="card-text mb-2">
              <strong>Study:</strong>
              <%= truncate(log.study.to_s, length: 60) %>
            </p>

            <p class="card-text mb-2">
              <strong>Implementation:</strong>
              <%= truncate(log.implementation.to_s, length: 60) %>
            </p>

            <div class="mb-3">
              <% log.tags.each do |tag| %>
                <%= link_to "##{tag.name}",
                            tag_path(tag),
                            class: "badge text-bg-secondary text-decoration-none me-1" %>
              <% end %>
            </div>

            <%= link_to "セーブデータをロードする", log_path(log), class: "btn btn-primary" %>
            <%= link_to "セーブを書き換える", edit_log_path(log), class: "btn btn-success" %>
            <%= link_to "セーブデータを削除する", 
                        log_path(log),
                        data: { turbo_method: :delete,
                                turbo_confirm: "削除したセーブデータは戻りません。それでもよろしいですか？" },
                        class: "btn btn-danger" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>