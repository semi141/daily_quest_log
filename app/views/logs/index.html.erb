<div class="container mt-4">
<%= link_to "新しくセーブする", new_log_path, class: "btn btn-success" %>
  <div class="row">
    <% @logs.each do |log| %>
      <div class="col-md-4 mb-4">
        <div class="card h-100">
          <div class="card-body d-flex flex-column">

            <p class="text-muted mb-1">
              <%= log.log_date %>
              <% if log.duration.present? %>
              ・ <%= format_duration(log.duration) %>
              <% end %>
            </p>

            <h5 class="card-title">
              <%= truncate(log.title, length: 17) %>
            </h5>

            <% if log.design.present? %>
              <p class="card-text mb-2">
                <strong>設計:</strong>
                <%= truncate(log.design, length: 17) %>
              </p>
            <% end %>

            <% if log.study.present? %>
              <p class="card-text mb-2">
                <strong>座学:</strong>
                <%= truncate(log.study, length: 17) %>
              </p>
            <% end %>

            <% if log.implementation.present? %>
              <p class="card-text mb-2">
                <strong>実装:</strong>
                <%= truncate(log.implementation, length: 17) %>
              </p>
            <% end %>

            <div class="mb-3">
              <% log.tags.each do |tag| %>
                <%= link_to "##{tag.name}",
                            tag_path(tag),
                            class: "badge text-bg-secondary text-decoration-none me-1" %>
              <% end %>
            </div>
              <div class="mt-auto d-grid gap-2">
              <%= link_to "セーブデータをロードする", log_path(log), class: "btn btn-primary" %>
              <%= link_to "セーブを書き換える", edit_log_path(log), class: "btn btn-success" %>
              <%= link_to "セーブデータを削除する", 
                          log_path(log),
                          data: { turbo_method: :delete,
                                  turbo_confirm: "削除したセーブデータは戻りません。それでもよろしいですか？" },
                          class: "btn btn-danger" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>