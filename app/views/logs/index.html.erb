<div class="container mt-4">
  <div class="row">
    <% @logs.each do |log| %>
      <div class="col-md-4 mb-4">
        <div class="card h-100">
          <div class="card-body d-flex flex-column">
            <h5 class="card-title"><%= log.title %></h5>

            <p class="card-text mb-2">
              <strong>Design:</strong>
              <%= truncate(log.design.to_s, length: 60) %>
            </p>

            <p class="card-text mb-2">
              <strong>Study:</strong>
              <%= truncate(log.study.to_s, length: 60) %>
            </p>

            <p class="card-text mb-2">
              <strong>Implementation:</strong>
              <%= truncate(log.implementation.to_s, length: 60) %>
            </p>

            <div class="mb-3">
              <span class="badge text-bg-secondary">タグ予定</span>
            </div>

            <%= link_to "詳細を見る", log_path(log), class: "btn btn-primary" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>