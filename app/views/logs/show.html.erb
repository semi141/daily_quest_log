<h1><%= @log.title %></h1>

<p>
  日付:<%= @log.log_date %><br>
  学習時間:<%= format_duration(@log.duration) %>
</p>

<hr>

<h2>設計</h2>
<p><%= simple_format(@log.design) %></p>

<hr>

<h2>座学</h2>
<p><%= simple_format(@log.study) %></p>

<hr>

<h2>実装</h2>
<p><%= simple_format(@log.implementation) %></p>

<hr>

<h3>メモ</h3>
<p><%= simple_format(@log.memo) %></p>

<h4>タグ</h4>
<% @log.tags.each do |tag| %>
  <span><%= link_to tag.name, tag_path(tag) %></span>
<% end %>