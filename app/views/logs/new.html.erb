<%= form_with model: @log  do |f| %>

  <div>
    <%= f.label :content %><br>
    <%= f.text_area :content %>
  </div>

  <div>
    <%= f.label :duration %><br>
    <%= f.number_field :duration %>
  </div>

  <div>
    <%= f.label :category %><br>
    <%= f.text_field :category %>
  </div>

  <div>
    <%= f.label :memo %><br>
    <%= f.text_area :memo %>
  </div>

  <div>
    <%= f.label :log_date %><br>
    <%= f.date_field :log_date %>
  </div>

  <div>
    <%= f.submit "保存する" %><br>
  </div>

  <% end %>