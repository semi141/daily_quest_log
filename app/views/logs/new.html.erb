<%= form_with model: @log  do |f| %>

  <div>
    <%= f.label :title, "タイトル" %><br>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :log_date, "日付" %><br>
    <%= f.date_field :log_date %>
  </div>

  <div>
    <%= f.label :duration, "学習した時間" %><br>
    <%= f.number_field :duration %>
  </div>

  <h4><%= f.label :design, "設計" %></h4>
  <%= f.text_area :design %>

  <h4><%= f.label :study, "座学" %></h4>
  <%= f.text_area :study %>

  <h4><%= f.label :implementation, "実装" %></h4>
  <%= f.text_area :implementation %>

  <div>
    <%= f.label :memo, "メモ" %><br>
    <%= f.text_area :memo %>
  </div>

  <div>
    <%= f.label :tag_names, "タグ(カンマ区切りで入力)" %><br>
    <%= f.text_field :tag_names %>
  </div>

  <div>
    <%= f.submit "EXPを獲得する" %><br>
  </div>

  <% end %>